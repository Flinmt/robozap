# Configuracao do Servidor Web
PORT=3000
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha
RUNTIME_CONFIG_PATH=config/runtime-config.json

# Configuracao do Banco de Dados SQL Server
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_SERVER=seu_servidor_sql
DB_NAME=biodata

# Configuracao da API PartnerBot (WhatsApp)
URL=https://api.partnerbot.com.br/api/v1/send
AUTH_TOKEN=seu_token_de_autenticacao

# Configuracao operacional padrao
TEMPLATE_NEW_SCHEDULE=templateexample
TEMPLATE_REMINDER=ttemplateexample2
PARTNERBOT_IS_CLOSED=true
PARTNERBOT_INCLUDE_COMPANY=true
PARTNERBOT_INCLUDE_UNIT=true
PARTNERBOT_INCLUDE_CONFIRMATION_BUTTON=true
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=17
QUEUE_PRODUCER_ENABLED=false
QUEUE_PRODUCER_LOOKAHEAD_DAYS=365
QUEUE_PRODUCER_LIMIT=25
TEST_MODE_ENABLED=false
TEST_PATIENT_NAME_FILTER=TESTE
SYNC_AGENDA_WHATSAPP_STATUS=false
MESSAGING_START_DATE=
SKIP_PAST_APPOINTMENT_TIME=false
OUTBOUND_SEND_START_DATE=
