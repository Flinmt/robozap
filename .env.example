# Configuracao do Servidor Web
PORT=3000
BASE_PATH=
INSTANCE_ID=cliente-local-01
RUNTIME_CONFIG_PATH=config/runtime-config.json

# Admin (seguranca)
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha
ADMIN_SESSION_SECRET=troque-este-segredo

# Identificacao opcional do cliente (fallback inicial do runtime-config)
CLIENT_NAME=
CLIENT_CODE=

# Configuracao do Banco de Dados SQL Server
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_SERVER=seu_servidor_sql
DB_NAME=biodata

# Configuracao da API PartnerBot (WhatsApp)
URL=https://api.partnerbot.com.br/api/v1/send
SHOWTICKET_URL=
AUTH_TOKEN=seu_token_de_autenticacao

# Regras avancadas de envio (opcionais)
USE_TICKET_OPEN_FOR_IS_CLOSED=false
NORMALIZE_BRAZIL_MOBILE_NINTH_DIGIT=true

# Observacao:
# Configuracoes operacionais (templates, janelas, flags de envio, modo teste)
# sao editadas no painel e persistidas em config/runtime-config.json.
